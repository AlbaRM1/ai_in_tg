# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_TELEGRAM_ID=123456789

# Database Configuration
# ВАЖНО: схема URL ОБЯЗАТЕЛЬНО должна содержать +asyncpg (или +aiosqlite для SQLite).
# Голая схема 'postgresql://' заставит SQLAlchemy искать синхронный psycopg2,
# которого в проекте нет — это приведёт к ошибке 'ModuleNotFoundError: psycopg2'.

# Основной вариант — PostgreSQL (рекомендуется для продакшена):
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/llm_bot

# Managed-PostgreSQL (Neon/Supabase) — данные вне хоста, миграция = передеплой:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require

# Запасной локальный вариант — SQLite (если PostgreSQL недоступен):
# DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Security (опционально, пока не используется)
# Для генерации ключа: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your_fernet_key_here

# Context Management
MAX_CONTEXT_TOKENS=200000
